---
import Link from './Link.astro';
---
<footer class="bg-black text-gray-400 py-8 mt-auto border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
                <h3 class="text-white font-bold text-lg mb-3">Grounds For Growth</h3>
                <p class="text-sm">A student-led engineering project focused on building a solar-powered, sustainable greenhouse system that integrates climate control, water collection, and automation.</p>
            </div>
            <div>
                <h3 class="text-white font-bold text-lg mb-3">Quick Links</h3>
                <ul class="space-y-2 text-sm">
                    <li><Link href="/projects" class="hover:text-indigo-400 transition-colors duration-150">Systems</Link></li>
                    <li><Link href="/about" class="hover:text-indigo-400 transition-colors duration-150">About</Link></li>
                    <li><Link href="/contact" class="hover:text-indigo-400 transition-colors duration-150">Contact</Link></li>
                </ul>
            </div>

            <div>
                <h3 class="text-white font-bold text-lg mb-3">Connect</h3>
                <div class="flex space-x-4">
                </div>
                <p class="text-sm mt-3">ayithiabhiram@gmail.com and sonnygsharmin@gmail.com</p>
            </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-6 text-center text-sm">
            <p>&copy; {new Date().getFullYear()} Sonny Sharmin and Abhi Ayithi All rights reserved.</p>
        </div>
    </div>
</footer>
